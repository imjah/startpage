{
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "emitDeclarationOnly": true,
    "allowJs": true,
    "noUncheckedSideEffectImports": true
  },
  "include": [
    "vite.config.js",
    "src/config.ts"
  ]
}